# Compose-only settings. Copy this file to .env, then create the secret files below.
COMPOSE_PROJECT_NAME=mongars
MONGARS_IMAGE=mongars:local
MONGARS_BIND_ADDRESS=127.0.0.1
MONGARS_API_PORT=8000
MONGARS_HTTPS_BIND_ADDRESS=127.0.0.1
MONGARS_HTTPS_HOST=127.0.0.1
# Set this to the group owner of secrets/*.txt (`id -g` on a single-user workstation).
MONGARS_SECRET_GID=1000

# Application settings. Keep remote inference disabled unless a reviewed policy enables it.
MONGARS_ENVIRONMENT=production
MONGARS_LOG_LEVEL=INFO
MONGARS_OWNER_ID=local-owner
MONGARS_CORS_ORIGINS=[]
MONGARS_TRUSTED_HOSTS=["localhost","127.0.0.1"]
MONGARS_MAX_REQUEST_BYTES=2100000
MONGARS_MAX_DOCUMENT_REQUEST_BYTES=10500000
MONGARS_MAX_DOCUMENT_UPLOAD_BYTES=10000000
MONGARS_MAX_DOCUMENT_PAGES=500
MONGARS_MAX_DOCUMENT_SECTIONS=10000
MONGARS_MAX_DOCUMENT_ARCHIVE_ENTRIES=2000
MONGARS_MAX_DOCUMENT_ARCHIVE_UNCOMPRESSED_BYTES=50000000
MONGARS_DOCUMENT_PARSER_TIMEOUT_SECONDS=30
MONGARS_DOCUMENT_PARSER_MEMORY_BYTES=536870912
MONGARS_DOCUMENT_PARSER_BASE_URL=http://parser:8091
MONGARS_ALLOW_REMOTE_DOCUMENT_PARSER=false
MONGARS_DOCUMENT_STAGING_TTL_SECONDS=86400
MONGARS_MAX_DOCUMENT_STAGED_OBJECTS=10
MONGARS_MAX_DOCUMENT_STAGED_BYTES=50000000
MONGARS_MAX_CONCURRENT_DOCUMENT_UPLOADS=2
MONGARS_MAX_CONCURRENT_DOCUMENT_UPLOADS_PER_OWNER=1
MONGARS_DATABASE_POOL_SIZE=5
MONGARS_DATABASE_POOL_TIMEOUT_SECONDS=10
MONGARS_INFERENCE_BACKEND=ollama
MONGARS_OLLAMA_BASE_URL=http://ollama:11434
MONGARS_OLLAMA_CHAT_MODEL=qwen3:4b-instruct
MONGARS_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
MONGARS_OLLAMA_EMBEDDING_MODEL_DIGEST=0a109f422b47e3a30ba2b10eca18548e944e8a23073ee3f3e947efcf3c45e59f
MONGARS_OLLAMA_THINK=false
MONGARS_OLLAMA_CONTEXT_LENGTH=4096
MONGARS_OLLAMA_NUM_PREDICT=512
MONGARS_INFERENCE_TIMEOUT_SECONDS=90
MONGARS_INFERENCE_HEALTH_TIMEOUT_SECONDS=2
MONGARS_WEB_SEARCH_ENABLED=true
MONGARS_P2P_READINESS_ENABLED=false
MONGARS_EXECUTOR_SECURITY_REVIEW_APPROVED=false
MONGARS_WEB_SEARCH_BASE_URL=http://searxng:8080
MONGARS_WEB_SEARCH_TIMEOUT_SECONDS=10
MONGARS_WEB_SEARCH_MAX_QUERY_CHARS=500
MONGARS_WEB_SEARCH_MAX_RESULTS=5
MONGARS_WEB_SEARCH_MAX_RESPONSE_BYTES=1000000
MONGARS_EMBEDDING_DIMENSIONS=768
MONGARS_EMBEDDING_BATCH_SIZE=16
MONGARS_EMBEDDING_MAX_INPUT_BYTES=8192
MONGARS_ALLOW_REMOTE_INFERENCE=false
MONGARS_MAX_CHAT_CHARS=32000
MONGARS_MAX_DOCUMENT_CHARS=2000000
MONGARS_MEMORY_CHUNK_TOKENS=800
MONGARS_MEMORY_CHUNK_OVERLAP_TOKENS=100
MONGARS_MEMORY_CHUNK_CHARACTERS=32000
MONGARS_MEMORY_TOP_K=8
MONGARS_WORKER_POLL_SECONDS=1
MONGARS_WORKER_LEASE_SECONDS=120
MONGARS_WORKER_RUNTIME_HEARTBEAT_SECONDS=10
MONGARS_WORKER_RUNTIME_STALE_SECONDS=45
MONGARS_RUNTIME_GIT_SHA=unknown
MONGARS_RUNTIME_VERSION=0.1.0
MONGARS_RETENTION_SWEEP_SECONDS=300
MONGARS_APPROVAL_TTL_SECONDS=900

# PostgreSQL is not published to the host. These identifiers are not secrets.
POSTGRES_DB=mongars
POSTGRES_USER=mongars
MONGARS_POSTGRES_IMAGE=pgvector/pgvector@sha256:9d2e61c7352b9e9f4798df5fd9a498f043f4cda1cdacc707de3d198650f4321e
MONGARS_CADDY_IMAGE=mongars-caddy:local
MONGARS_SEARXNG_IMAGE=docker.io/searxng/searxng@sha256:b8ca38ba06eea544d7555e88321e212ddc0d5c3c7de055419cfb2e5c6bf30812
MONGARS_SQUID_IMAGE=ubuntu/squid@sha256:8a3baed477e2c282ab8aa5edad442f69873246964f225c5c2ae8364b6610963c
MONGARS_SEARXNG_SECRET_FILE=./secrets/searxng_secret.txt

# Secret files must contain one value and end with a newline. Never commit secrets/.
# Generate them before first startup, for example:
#   install -m 0700 -d secrets
#   openssl rand -hex 32 > secrets/postgres_password.txt
#   openssl rand -hex 32 > secrets/api_token.txt
#   openssl rand -hex 32 > secrets/approval_hmac_key.txt
#   openssl rand -hex 32 > secrets/searxng_secret.txt
#   chgrp "$(id -g)" secrets/*.txt
#   chmod 0640 secrets/*.txt
MONGARS_POSTGRES_PASSWORD_FILE=./secrets/postgres_password.txt
MONGARS_API_TOKEN_FILE=./secrets/api_token.txt
MONGARS_APPROVAL_HMAC_KEY_FILE=./secrets/approval_hmac_key.txt

# Optional inference image profiles for deployment targets.
# Update reviewed tags/digests deliberately for any profile image change.
MONGARS_OLLAMA_IMAGE=ollama/ollama@sha256:6345fbc18bd73a1e16404be681dbc6fd291a027cab43ed541abe78c4c81051b0
MONGARS_OLLAMA_IMAGE_ARM64=ollama/ollama:latest
MONGARS_OLLAMA_IMAGE_JETSON=ollama/ollama:latest
MONGARS_OLLAMA_KEEP_ALIVE=5m
