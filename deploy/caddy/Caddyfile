{
	admin off
	auto_https disable_redirects
	http_port 8080
	https_port 8443
	skip_install_trust
	default_sni {$MONGARS_HTTPS_HOST}

	servers {
		protocols h1 h2
	}
}

https://{$MONGARS_HTTPS_HOST} {
	tls internal

	request_body {
		max_size {$MONGARS_MAX_REQUEST_BYTES}
	}

	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
	}

	reverse_proxy api:8000
}

http://{$MONGARS_HTTPS_HOST} {
	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
	}

	@root_ca path /mongars-local-ca.crt
	handle @root_ca {
		root * /data/caddy/pki/authorities/local
		rewrite * /root.crt
		header Content-Type application/x-x509-ca-cert
		header Content-Disposition "attachment; filename=monGARS-local-CA.crt"
		header Cache-Control "no-store"
		file_server
	}

	handle {
		respond "Not Found" 404
	}
}

# Preserve the workstation-only HTTP control-plane address while keeping the Python
# application on internal Docker networks. Compose publishes this listener on loopback.
http://:8001 {
	request_body {
		max_size {$MONGARS_MAX_REQUEST_BYTES}
	}

	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
	}

	reverse_proxy api:8000
}
